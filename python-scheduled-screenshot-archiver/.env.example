# Required for live captures. Leave empty when SCREENSHOTAPI_DRY_RUN=true.
SCREENSHOTAPI_KEY=

# Optional. Use true for local smoke tests without real secrets.
SCREENSHOTAPI_DRY_RUN=true

# Optional. Override only for local API gateways or test doubles.
SCREENSHOTAPI_BASE_URL=https://screenshotapi.to

# Optional. Output directory for dated archives.
SCREENSHOTAPI_OUTPUT_DIR=archives

# Required for live captures. Add to Cloudflare as a secret:
# bunx wrangler secret put SCREENSHOTAPI_KEY
SCREENSHOTAPI_KEY=

# Optional. Use true for local smoke tests without real secrets.
SCREENSHOTAPI_MOCK_MODE=true

# Optional. Override only for local API gateways or test doubles.
SCREENSHOTAPI_BASE_URL=https://screenshotapi.to

# Optional. Cache successful proxy responses at the edge.
CACHE_TTL_SECONDS=300

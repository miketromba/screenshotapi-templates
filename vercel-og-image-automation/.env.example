# Required for live OG image generation.
SCREENSHOTAPI_KEY=

# Required in production so ScreenshotAPI can reach your deployed template page.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional. Use this for local smoke tests and previews without real secrets.
SCREENSHOTAPI_MOCK_MODE=true

# Optional. Override only for local API gateways or test doubles.
SCREENSHOTAPI_BASE_URL=https://screenshotapi.to
